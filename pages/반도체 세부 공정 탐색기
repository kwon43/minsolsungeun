import streamlit as st
import pandas as pd
import os

st.set_page_config(
    page_title="반도체 공정 탐구 앱",
    page_icon="🔬",
    layout="wide"
)

@st.cache_data
def load_data():
    file_name = "한국나노기술원_공정 정보_20260226.csv"
    if not os.path.exists(file_name):
        st.error(f"'{file_name}' 파일을 찾을 수 없습니다. 루트 폴더에 파일을 넣어주세요.")
        return None
    try:
        df = pd.read_csv(file_name, encoding='utf-8-sig')
    except UnicodeDecodeError:
        try:
            df = pd.read_csv(file_name, encoding='cp949')
        except Exception as e:
            st.error(f"파일을 읽는 중 오류가 발생했습니다: {e}")
            return None
    df.columns = ['기관명', '공정코드', '공정명', '공정그룹코드', '공정그룹']
    return df

df = load_data()

st.title("🔬 한국나노기술원 데이터를 활용한 반도체 공정 탐구")
st.subheader("당곡고등학교 학생들을 위한 반도체 공정 학습 가이드")

st.markdown("""
반도체는 현대 과학기술의 정점입니다.  
모래(규소)에서 시작해 스마트폰과 컴퓨터의 두뇌인 칩이 되기까지 수백 가지의 정밀한 공정을 거칩니다.

이 웹앱은 **한국나노기술원의 실제 공정 데이터**를 바탕으로,  
반도체 제조 공정의 구조를 이해하고 수율을 높이기 위해  
어떤 기술들이 사용되는지 스스로 분석해 볼 수 있도록 설계되었습니다.
""")

if df is not None:
    st.success(f"✅ 데이터 로드 완료! 총 **{len(df)}개** 공정이 등록되어 있습니다.")

    st.markdown("---")

    col1, col2 = st.columns(2)

    with col1:
        st.write("### 📌 데이터 미리보기 (상위 10개 행)")
        st.dataframe(df.head(10), use_container_width=True)

    with col2:
        st.write("### 📊 공정그룹별 공정 수 분포")
        group_counts = df['공정그룹'].value_counts()
        st.bar_chart(group_counts)

    st.markdown("---")
    st.markdown("""
    ### 🧭 페이지 안내
    왼쪽 사이드바 메뉴에서 원하는 페이지를 선택하세요.

    | 페이지 | 내용 |
    |--------|------|
    | 🔍 공정 탐색기 | 공정그룹 필터와 검색으로 세부 공정을 탐색 |
    | 📈 중요 공정과 수율 | 검사·계측·신뢰성 공정이 수율에 미치는 영향 분석 |
    """)
